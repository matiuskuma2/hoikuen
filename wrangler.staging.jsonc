{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ayukko-stg",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ayukko-staging",
      "database_id": "6352b540-f309-4fcb-bc8d-c8991bc4ae91"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "ayukko-files-stg"
    }
  ]
}
