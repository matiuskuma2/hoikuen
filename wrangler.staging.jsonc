{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ayukko-stg",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ayukko-staging",
      "database_id": "285fa9a7-0344-444c-962e-c3e7f60b33ac"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "ayukko-files-stg"
    }
  ]
}
